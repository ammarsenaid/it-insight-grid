# IT Knowledge Center — frontend environment placeholders.
# Values are provided at deployment time on the VPS. Never commit real values.
#
# Self-hosted Supabase gateway URL reachable from the browser
# (example: http://192.168.2.28:8000 — set the real value in the deployment env).
VITE_SUPABASE_URL=

# Public anonymous (publishable) Supabase key.
# This is the ONLY Supabase credential that may appear in the browser.
# Never put SERVICE_ROLE_KEY, JWT secret, or DB password here.
VITE_SUPABASE_ANON_KEY=
